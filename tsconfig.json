{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node"]
  },
  "include": [
    "server.js",
    "app/backend/**/*.js",
    "app/backend/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "public",
    "img",
    "video"
  ]
}
